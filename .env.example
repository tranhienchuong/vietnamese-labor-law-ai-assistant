# LLM runtime
APP_ENV=development
ENVIRONMENT=
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=qwen/qwen3-32b

# Query routing
QUERY_ROUTER_ENABLED=1
QUERY_ROUTER_PROVIDER=groq
QUERY_ROUTER_MODEL=llama-3.1-8b-instant
QUERY_ROUTER_FALLBACK_TO_HEURISTIC=1

# Official deterministic benchmark and validation
BENCHMARK_PATH=artifacts/evaluation/golden_benchmark_100_extended.jsonl
BENCHMARK_METRIC_MODE=deterministic_100_split
CITATION_VALIDATION_MODE=deterministic
EVAL_CITATION_MATCH_MODE=containment

# Qdrant Cloud / server
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=vietnamese_labor_law_chunks
QDRANT_TIMEOUT=120

# Retriever runtime
RETRIEVER_RECORD_SOURCE=qdrant_payload
INDEX_PATH=artifacts/index
RERANKER_MODEL=
RERANKER_TOP_N=24
ENABLE_ARTICLE_SIBLING_CONTEXTS=true
SIBLING_CONTEXT_LIMIT=8
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_API_URL=
EMBEDDING_API_TOKEN=
# Optional fallbacks used when EMBEDDING_API_TOKEN is empty.
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
EMBEDDING_API_TIMEOUT_SECONDS=60

# Neo4j Legal Graph expansion
LEGAL_GRAPH_ENABLED=false
LEGAL_GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
LEGAL_GRAPH_EXPANSION_DEPTH=2
LEGAL_GRAPH_MAX_EXPANDED_CHUNKS=12
LEGAL_GRAPH_MIN_CONFIDENCE=0.60
LEGAL_GRAPH_COMPLEX_QUERY_ONLY=true
LEGAL_GRAPH_TRACE=false

# Index build
# Matches artifacts/index/current.json. Rebuild Qdrant if this changes.
DENSE_MODEL=keepitreal/vietnamese-sbert

# Backend API
CORS_ALLOW_ORIGINS=http://localhost:5173
# Local development can still use SQLite. Production should set APP_DATA_BACKEND=supabase.
APP_DATA_BACKEND=sqlite
APP_DB_PATH=artifacts/app.db
AUTH_PROVIDER=local
AUTH_SECRET=replace_with_a_long_random_secret
# Development can seed sample users. In production, set AUTH_SEED_DEFAULT_USERS=0
# or replace both default passwords below before startup.
AUTH_SEED_DEFAULT_USERS=1
DEFAULT_USER_NAME=Nguoi dung
DEFAULT_USER_EMAIL=user@example.com
DEFAULT_USER_PASSWORD=user12345
DEFAULT_ADMIN_NAME=Quan tri vien
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin12345

# Supabase Auth for production frontend
# Set AUTH_PROVIDER=supabase and APP_DATA_BACKEND=supabase on Render.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres
# Optional only if local JWT verification is added later.
SUPABASE_JWT_SECRET=
# Comma-separated emails that should receive admin role in Supabase mode.
ADMIN_EMAILS=your@email.com

# Frontend Vercel
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_BASE_URL=https://your-backend.onrender.com
